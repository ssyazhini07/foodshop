<html>

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delicious Food Shop</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
            font-style: italic;
        }

        body {
            background: #fff8f0;
            color: #333333;
            transition: 0.3s;
        }

        /* Dark mode */
        .dark-mode {
            background: #121212;
            color: white;
        }

        .dark-mode .section,
        .dark-mode .hero,
        .dark-mode footer,
        .dark-mode nav {
            color: white;
        }

        .dark-mode #menu div {
            background: #1e1e1e !important;
            color: white !important;
            border: 1px solid #444;
        }

        /* Navbar */
        nav {
            background: palevioletred;
            color: white;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 40px;
            position: sticky;
            top: 0;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 24px;
            font-weight: bold;
        }

        .logo img {
            width: 50px;
            height: 50px;
            border-radius: 50%;
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 25px;
        }

        nav ul li a {
            color: white;
            text-decoration: none;
            font-size: 18px;
        }

        nav ul li a:hover {
            color: #667aff;
        }

        .hero {
            text-align: center;
            padding: 60px 20px;
            background:          
                    linear-gradient(rgba(0, 0, 0, 0.5),
                    rgba(0, 0, 0, 0.5)),
                url('https://images.unsplash.com/photo-1504674900247-0877df9cc836');
            background-size: cover;
            color: white;
        }

        .hero h1 {
            font-size: 50px;
            margin-bottom: 20px;
        }

        .hero p {
            font-size: 22px;
        }

        .section {
            padding: 50px 20px;
            text-align: center;
        }

        .food-gallery {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
            margin-top: 30px;
        }

        .food-gallery img {
            width: 300px;
            height: 220px;
            border-radius: 15px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
        }

        .video-section video {
            width: 500px;
            max-width: 90%;
            border-radius: 15px;
            margin-top: 20px;
        }

        footer {
            background: #6828d6;
            color: white;
            text-align: center;
            padding: 20px;
            margin-top: 30px;
        }

        .popup {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .popup-content {
            background: white;
            padding: 30px;
            border-radius: 15px;
            text-align: center;
            width: 320px;
        }

        .popup-content input {
            width: 90%;
            padding: 10px;
            margin: 10px 0;
            border: 1px solid gray;
            border-radius: 8px;
        }

        .popup-content button {
            background: palevioletred;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
        }

        .close-btn {
            float: right;
            font-size: 25px;
            cursor: pointer;
            color: red;
        }
    </style>
</head>

<body>

  <div id="detailsPopup" class="popup">
    <div class="popup-content">
        <span class="close-btn" onclick="closeDetailsForm()">&times;</span>

        <h2>Enter Your Details</h2><br>
        <label>Name</label>
        <input id="name" type="text" placeholder="Enter Name">
        <label>Phone number</label>
        <input id="phone" type="text" placeholder="Enter Phone Number">
        <label>Address</label>
        <input id="address" type="text" placeholder="Enter Address">

        <button onclick="submitDetails()">Submit</button>
    </div>
</div>
    <nav>
        <div class="logo">
            <img src="https://cdn-icons-png.flaticon.com/512/3075/3075977.png">
            Tasty Bites
        </div>

        <ul>
            <li><a href="#home">Home</a></li>
            <li><a href="#menu">Menu</a></li>
            <li><a href="#gallery">Gallery</a></li>
            <li><a href="#videos">Videos</a></li>
            <li><a href="#contact">Contact</a></li>
            <li><a href="#" onclick="openDetailsForm()">Details</a></li>
        </ul>

        <button onclick="toggleDarkMode()"
            style="padding:10px 15px; border:none; border-radius:8px; cursor:pointer;">
            🌙 Dark Mode
        </button>
    </nav>

    <section class="hero" id="home">
        <h1>Welcome to Tasty Bites</h1>
        <p>Fresh, Delicious, and Tasty Food</p>
    </section>

    <section class="section" id="menu">
        <h2>Our Menu</h2>

        <div style="display:flex; justify-content:center; gap:20px; flex-wrap:wrap; margin-top:30px;">

            <div style="background:white; padding:20px; border-radius:15px; width:220px;
            box-shadow:0 4px 10px rgba(0,0,0,0.2);">
                <h3>🍕 Pizza</h3>
                <p>Cheesy delight with fresh toppings</p>
                <h4>₹299</h4>
            </div>

            <div style="background:white; padding:20px; border-radius:15px; width:220px;
            box-shadow:0 4px 10px rgba(0,0,0,0.2);">
                <h3>🍔 Burger</h3>
                <p>Juicy grilled burger with fries</p>
                <h4>₹199</h4>
            </div>

            <div style="background:white; padding:20px; border-radius:15px; width:220px;
            box-shadow:0 4px 10px rgba(0,0,0,0.2);">
                <h3>🥗 Salad</h3>
                <p>Healthy fresh green salad</p>
                <h4>₹149</h4>
            </div>

        </div>
    </section>

    <section class="section" id="gallery">
        <h2>Our Special Foods</h2>

        <div class="food-gallery">
            <img src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38">
            <img src="https://images.unsplash.com/photo-1550547660-d9450f859349">
            <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c">
        </div>
    </section>

    <section class="section video-section" id="videos">
        <h2>Watch Our Food Story</h2>

        <video controls poster="https://images.unsplash.com/photo-1550547660-d9450f859349">
            <source src="https://www.w3schools.com/html/mov_bbb.mp4" type="video/mp4">
        </video>
    </section>

    <footer id="contact">
        <h3>Contact Us</h3>
        <p>📍 Kottai, Tamil Nadu, India</p>
        <p>📞 +91 98765 43210</p>
        <p>✉ info@tastybites.com</p>
        <p>🕒 Open Daily: 9:00 AM - 11:00 PM</p>

        <div style="margin-top:15px;">
            <a href="#" style="color:white;">Facebook</a> |
            <a href="#" style="color:white;">Instagram</a> |
            <a href="#" style="color:white;">WhatsApp</a>
        </div>

        <p style="margin-top:15px;">© 2026 Tasty Bites | All Rights Reserved</p>
    </footer>

    <script>
        function toggleDarkMode() {
            document.body.classList.toggle("dark-mode");
        }
    </script>
<script>
function openDetailsForm() {
    document.getElementById("detailsPopup").style.display = "flex";
}

function closeDetailsForm() {
    document.getElementById("detailsPopup").style.display = "none";
}

function submitDetails() {
    const name = document.getElementById("name").value;
    const phone = document.getElementById("phone").value;
    const address = document.getElementById("address").value;

    fetch("http://localhost:5000/save-details", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify({
            name,
            phone,
            address
        })
    })
    .then(res => res.json())
    .then(data => {
        alert(data.message);

        if (data.success) {
            closeDetailsForm();
        }
    })
    .catch(err => {
        console.log(err);
        alert("Server error");
    });

}
</script>

</body>

</html>